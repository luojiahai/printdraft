{
  "name": "printdraft",
  "version": "0.1.0",
  "description": "CLI and library for creating professional PDF resumes and cover letters",
  "repository": {
    "url": "https://github.com/luojiahai/printdraft"
  },
  "type": "module",
  "bin": {
    "printdraft": "./bin/printdraft.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "scripts": {
    "dev": "vite",
    "build:app": "vite build",
    "build:lib": "tsc -p tsconfig.node.json",
    "build": "pnpm build:app && pnpm build:lib"
  },
  "keywords": ["resume", "cover-letter", "pdf", "cli"],
  "license": "MIT",
  "dependencies": {
    "vue": "^3.4.0",
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "chokidar": "^3.6.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.22.4",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "@inquirer/prompts": "^5.0.0",
    "puppeteer": "^22.0.0",
    "open": "^10.1.0",
    "get-port": "^7.1.0"
  },
  "devDependencies": {
    "vite": "^5.2.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "typescript": "^5.4.0",
    "@types/node": "^20.12.0",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/js-yaml": "^4.0.9",
    "codemirror": "^6.0.1",
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-yaml": "^6.1.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.26.1",
    "@codemirror/state": "^6.4.1"
  }
}
