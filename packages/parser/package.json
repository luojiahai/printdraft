{
  "name": "@draftjs/parser",
  "version": "0.1.1",
  "description": "Document parser for draft",
  "repository": {
    "url": "https://github.com/luojiahai/printdraft"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts && tsc -p tsconfig.build.json",
    "dev": "tsdown src/index.ts --watch",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "keywords": [
    "draft",
    "resume",
    "parser"
  ],
  "license": "MIT",
  "dependencies": {
    "@draftjs/types": "workspace:*",
    "js-yaml": "catalog:prod"
  },
  "devDependencies": {
    "@types/js-yaml": "catalog:types",
    "@types/node": "catalog:types",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.2"
}
