{
  "name": "@printdraft/cli",
  "version": "0.1.3",
  "description": "CLI for creating professional PDF resumes and cover letters",
  "repository": {
    "url": "https://github.com/luojiahai/printdraft"
  },
  "type": "module",
  "bin": {
    "draft": "./bin/draft.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "bin",
    "dist",
    "templates",
    "src/app"
  ],
  "scripts": {
    "build:lib": "tsc -p tsconfig.node.json",
    "build": "pnpm build:lib",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "draft",
    "resume",
    "cover-letter",
    "pdf",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@printdraft/components": "workspace:*",
    "@inquirer/prompts": "catalog:prod",
    "@vitejs/plugin-vue": "catalog:frontend",
    "chalk": "catalog:prod",
    "commander": "catalog:prod",
    "open": "catalog:prod",
    "puppeteer": "catalog:prod",
    "vue": "catalog:prod",
    "vite": "catalog:dev"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "typescript": "catalog:dev"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.2"
}
