{
  "name": "@draftjs/themes",
  "version": "0.1.1",
  "description": "Document themes for draft",
  "repository": {
    "url": "https://github.com/luojiahai/printdraft"
  },
  "exports": {
    ".": "./index.ts",
    "./resume-classic": "./resume-classic/index.ts",
    "./resume-modern": "./resume-modern/index.ts",
    "./resume-compact": "./resume-compact/index.ts",
    "./cover-letter": "./cover-letter/index.ts",
    "./*": "./*"
  },
  "main": "./index.ts",
  "files": [
    "**/*.ts",
    "**/*.vue",
    "**/*.css"
  ],
  "keywords": [
    "draft",
    "resume",
    "themes"
  ],
  "license": "MIT",
  "dependencies": {
    "@draftjs/types": "workspace:*",
    "vue": "catalog:prod"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.2"
}
